{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python3", "nodejs_20", "pnpm"]
        },
        "install": {
          "cmds": [
            "pip3 install -r server/requirements.txt"
          ]
        }
      },
      "start": {
        "cmd": "cd server && python3 -m uvicorn main:app --host 0.0.0.0 --port $PORT"
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/health"
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
