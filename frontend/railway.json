{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "env": {
        "NODE_VERSION": "20"
      },
      "phases": {
        "install": {
          "cmds": ["npm install -g pnpm@9", "pnpm install --force"]
        },
        "build": {
          "cmds": ["pnpm run build"]
        }
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
